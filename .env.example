# ZeroProof configuration — copy to `.env` for local dev only.
# NEVER bake secrets into the image or commit a real .env (see .gitignore).
# The grader injects Fireworks vars at runtime; do not hardcode them.

# ---- Local model ----
ZP_MODEL_PATH=/models/model.gguf
ZP_N_THREADS=2
ZP_N_CTX=4096

# ---- Timing guards (seconds) ----
ZP_WATCHDOG_SECONDS=570
ZP_PER_TASK_SECONDS=28
ZP_REMOTE_TIMEOUT=25

# ---- Fireworks valve: DEFAULT OFF (the winning 0-token path). ----
# Set to 1 ONLY as a documented last-resort insurance lever (factual only).
ZP_FIREWORKS_ENABLED=0
ZP_FIREWORKS_CATEGORIES=factual_knowledge

# ---- Injected by the grader at evaluation time (do NOT set these yourself,
#      do NOT hardcode, do NOT commit). Shown here for reference only. ----
# FIREWORKS_API_KEY=<injected by harness>
# FIREWORKS_BASE_URL=<injected by harness>
# ALLOWED_MODELS=<injected by harness, comma-separated>
